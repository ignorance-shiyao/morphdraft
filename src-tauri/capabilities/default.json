{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "默认能力：原生另存为 / 读取备份文件",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "dialog:default",
    "fs:default",
    "fs:allow-write-file",
    "fs:allow-read-text-file",
    "fs:allow-read-file",
    "fs:allow-mkdir",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }]
    },
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "markitdown", "cmd": "markitdown", "args": true }
      ]
    }
  ]
}

{
  "name": "morphdraft",
  "private": true,
  "version": "0.1.0-beta",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "package:all": "node scripts/package-all.mjs",
    "package:macos": "node scripts/run-tauri-with-rustup.mjs build --target universal-apple-darwin --bundles app,dmg",
    "package:macos:arm64": "node scripts/run-tauri-with-rustup.mjs build --target aarch64-apple-darwin --bundles app,dmg",
    "package:macos:x64": "node scripts/run-tauri-with-rustup.mjs build --target x86_64-apple-darwin --bundles app,dmg",
    "package:windows": "node scripts/run-tauri-with-rustup.mjs build --bundles nsis,msi",
    "package:linux": "node scripts/run-tauri-with-rustup.mjs build --bundles appimage,deb,rpm",
    "mobile:init:android": "node scripts/run-tauri-with-rustup.mjs android init",
    "mobile:init:ios": "node scripts/run-tauri-with-rustup.mjs ios init",
    "package:android": "node scripts/run-tauri-with-rustup.mjs android build --apk --aab",
    "package:ios": "node scripts/run-tauri-with-rustup.mjs ios build --export-method app-store-connect",
    "package:ios:unsigned": "node scripts/run-tauri-with-rustup.mjs ios build --no-sign"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.7.0",
    "@lezer/highlight": "^1.2.3",
    "@llamaindex/liteparse-wasm": "^2.1.1",
    "@slidev/parser": "^52.16.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@types/file-saver": "^2.0.7",
    "@types/reveal.js": "^5.2.2",
    "@types/turndown": "^5.0.6",
    "codemirror": "^6.0.1",
    "docx": "^9.7.1",
    "echarts": "^6.1.0",
    "file-saver": "^2.0.5",
    "highlight.js": "^11.11.1",
    "html-docx-js-typescript": "^0.1.5",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "markdown-it": "^14.1.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-ins": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "mermaid": "^11.15.0",
    "modern-screenshot": "^4.7.0",
    "pdfjs-dist": "^6.0.227",
    "pinia": "^2.2.6",
    "pptxgenjs": "^4.0.1",
    "reveal.js": "^6.0.1",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "vue": "^3.5.13",
    "vue-i18n": "^11.4.6",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.6.3",
    "vite": "6.4.3",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.1.10"
  }
}
